# Target API URL that SentinelAI will proxy and monitor
TARGET_API=https://httpbin.org

# SentinelAI proxy server settings
PROXY_HOST=127.0.0.1
PROXY_PORT=8080

# Alert settings (use Gmail App Password)
ALERT_EMAIL_FROM=your_email@gmail.com
ALERT_EMAIL_TO=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_gmail_app_password
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=465

# Threat thresholds
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
HIGH_RISK_SCORE_THRESHOLD=70
